# BuildKit honors this per-Dockerfile ignore file (named <dockerfile>.dockerignore,
# next to the Dockerfile) and it takes precedence over a root .dockerignore. Keeps the
# build context to just the Cargo workspace; everything cargo-chef needs (crates/,
# Cargo.toml, Cargo.lock) is kept.
**/target/
.git/
**/node_modules/
web/dist/
bench/
site/
docs/
deploy/
python/
.github/
scratchpad/
**/*.parquet
**/*.tbl
**/.DS_Store
