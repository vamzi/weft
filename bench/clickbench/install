#!/usr/bin/env bash
# Install build prerequisites for the Weft ClickBench entry (Amazon Linux 2023 or Ubuntu).
set -euo pipefail

if command -v dnf >/dev/null 2>&1; then
  sudo dnf install -y gcc gcc-c++ make cmake openssl-devel pkgconfig curl tar gzip
elif command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get install -y build-essential cmake pkg-config libssl-dev curl tar gzip
fi

# Rust 1.90+ (the runtime crates need a recent compiler).
if ! command -v cargo >/dev/null 2>&1; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.90.0
  # shellcheck disable=SC1091
  source "$HOME/.cargo/env"
fi

echo "[install] done. Next: ./bench/clickbench/benchmark.sh"
